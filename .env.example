# ── Jira connection (Data Center / Server) ────────────────────────────────────
# Base URL of your Jira instance, no trailing slash.
JIRA_BASE_URL=https://jira.your-company.com
# Personal Access Token (Jira DC: Profile → Personal Access Tokens).
JIRA_PAT=your-personal-access-token

# ── Default scope (optional; can also be set in the UI) ───────────────────────
# Comma-separated Jira project keys to limit syncing to.
JIRA_PROJECT_KEYS=PROJ
# Comma-separated labels to limit scope (optional).
JIRA_LABELS=
# Extra JQL appended to every scoped search (optional).
JIRA_EXTRA_JQL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Where the SQLite cache + config live. A Docker volume mounts here.
DATA_DIR=./data
# Secret used to encrypt the PAT at rest in SQLite (change me).
ENCRYPTION_KEY=change-me-to-a-long-random-string

# ── MCP safety switches ───────────────────────────────────────────────────────
# Allow MCP write tools at all (false = read-only server).
MCP_ALLOW_WRITE=true
# Default for whether MCP writes hit real Jira (false = cache-only until opted in).
MCP_APPLY_TO_JIRA=false
