{
  "name": "jira-explorer",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted, AI-native requirement-coverage explorer. Jira Data Center is the first tracker; the engine is tracker-agnostic.",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/app",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch packages/app/src/server/index.ts",
    "dev:web": "npm run dev -w @jira-explorer/web",
    "build:web": "npm run build -w @jira-explorer/web",
    "serve": "npm run build:web && tsx packages/app/src/server/index.ts",
    "start": "tsx packages/app/src/server/index.ts",
    "mcp:stdio": "tsx packages/app/src/mcp/stdio.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck -w @jira-explorer/web",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
